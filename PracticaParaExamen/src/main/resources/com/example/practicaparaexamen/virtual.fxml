<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="400.0" prefWidth="600.0"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.practicaparaexamen.controllers.AppController">
    <children>

        <VBox spacing="15" layoutX="120" layoutY="20">

            <Label text="Registro de Contactos de Emergencia">
                <font>
                    <Font size="18"/>
                </font>
            </Label>

            <GridPane hgap="10" vgap="10">

                <Label text="Nombre:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                <TextField fx:id="txtNombre" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                <Label text="Teléfono:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                <TextField fx:id="txtTelefono" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                <Label text="Parentesco:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                <ComboBox fx:id="cmbParentesco" GridPane.rowIndex="2" GridPane.columnIndex="1"/>

            </GridPane>

            <HBox spacing="10">
                <Button text="Agregar" onAction="#agregar"/>
                <Button text="Buscar" onAction="#buscar"/>
                <Button text="Actualizar" onAction="#actualizar"/>
                <Button text="Eliminar" onAction="#eliminar"/>
                <Button text="Limpiar" onAction="#limpiar"/>
            </HBox>

            <Label fx:id="lblMsg" text=""/>

            <Label text="Lista de contactos:"/>

            <ListView fx:id="listView" prefHeight="200" prefWidth="350"/>

        </VBox>

    </children>
</AnchorPane>